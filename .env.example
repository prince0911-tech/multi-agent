
# ─────────────────────────────────────────────
# Google Gemini API Configuration
# Get your free API key at https://ai.google.dev
# Free tier: ~1,000 requests/day, no credit card required
# ─────────────────────────────────────────────
GOOGLE_API_KEY=your-google-api-key-here
GEMINI_MODEL=gemini-2.5-flash


# ─────────────────────────────────────────────
# MongoDB Configuration
# ─────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=multi_agent_db

# ─────────────────────────────────────────────
# Application Settings
# ─────────────────────────────────────────────
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8080
SECRET_KEY=your-secret-key-change-in-production

# CORS — set to specific origins in production (comma-separated)
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
CORS_ORIGINS=*

# ─────────────────────────────────────────────
# Scheduler Settings
# ─────────────────────────────────────────────
SCHEDULER_TIMEZONE=UTC
DEADLINE_CHECK_INTERVAL_MINUTES=30

# ─────────────────────────────────────────────
# Vector Memory Settings
# ─────────────────────────────────────────────
FAISS_INDEX_PATH=./data/faiss_index
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ─────────────────────────────────────────────
# Risk Detection Thresholds
# ─────────────────────────────────────────────
OVERDUE_WARNING_HOURS=24
OVERLOAD_TASK_THRESHOLD=10
